{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/api.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/(.*)",                 "dest": "/server/api.js" },
    { "src": "/auth/google",              "dest": "/server/api.js" },
    { "src": "/auth/google/callback",     "dest": "/server/api.js" },
    { "src": "/health",                   "dest": "/server/api.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",                     "dest": "/index.html" }
  ]
}

