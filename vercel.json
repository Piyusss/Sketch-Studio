{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-api-backend.vercel.app/api/:path*"
    },
    {
      "source": "/auth/:path*",
      "destination": "https://your-api-backend.vercel.app/auth/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
